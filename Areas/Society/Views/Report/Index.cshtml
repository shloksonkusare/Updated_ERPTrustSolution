@{
    ViewData["Title"] = "Fees Report";
}

<div class="container mt-4">
    <h4 class="fw-bold mb-3">Fees Report Viewer</h4>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-warning d-flex align-items-center gap-2">
            <span>@ViewBag.Error</span>
            <a asp-area="Society" asp-controller="AccountWiseAbstract" asp-action="Index"
                   class="btn btn-sm btn-primary ms-auto">
                Generate Report
            </a>
        </div>
    }
    else
    {
        <div class="mb-2 d-flex gap-2">
            <a href="@Url.Action("DownloadPdf", "Report", new { area = "Society" })"
                   class="btn btn-outline-secondary btn-sm">
                ⬇ Download PDF
            </a>
        </div>

        <div class="border rounded" style="height:80vh">
            <iframe src="@Url.Action("ViewPdf", "Report", new { area = "Society" })"
                    width="100%" height="100%" style="border:none">
                <p>
                    Your browser does not support PDF viewing.
                    <a href="@Url.Action("DownloadPdf", "Report", new { area = "Society" })">Download the PDF</a>.
                </p>
            </iframe>
        </div>
    }
</div>
