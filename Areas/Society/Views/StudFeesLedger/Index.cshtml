@model ERPTrustSolution.Models.StudFeesLedgerViewModel
@{
    ViewData["Title"] = "Student Fees Ledger";
}

<div class="container-fluid mt-3">
    <h4 class="fw-bold mb-3">Student Fees Ledger</h4>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @* {{!-- ── College / Year selectors ── --}} *@
    <div class="row g-2 mb-3">
        <div class="col-md-3">
            <form asp-controller="StudFeesLedger" asp-action="ChangeCollege"
                  asp-area="Society" method="post">
                @Html.AntiForgeryToken()
                <label class="form-label fw-semibold">College</label>
                <select name="SelectedCollegeId" class="form-select" onchange="this.form.submit()">
                    @foreach (var c in Model.Colleges)
                    {
                        <option value="@c.Id" selected="@(c.Id == Model.SelectedCollegeId)">
                            @c.CollegeName
                        </option>
                    }
                </select>
                <input type="hidden" name="SelectedAcadYear" value="@Model.SelectedAcadYear" />
            </form>
        </div>

        <div class="col-md-2">
            <form asp-controller="StudFeesLedger" asp-action="ChangeAcadYear"
                  asp-area="Society" method="post">
                @Html.AntiForgeryToken()
                <label class="form-label fw-semibold">Academic Year</label>
                <select name="SelectedAcadYear" class="form-select" onchange="this.form.submit()">
                    @foreach (var y in Model.AcadYears)
                    {
                        <option value="@y" selected="@(y == Model.SelectedAcadYear)">@y</option>
                    }
                </select>
                <input type="hidden" name="SelectedCollegeId" value="@Model.SelectedCollegeId" />
            </form>
        </div>
    </div>

    @* {{!-- ── Student search ── --}} *@
    <form asp-controller="StudFeesLedger" asp-action="SearchStudent"
          asp-area="Society" method="post" class="row g-2 mb-4 align-items-end">
        @Html.AntiForgeryToken()
        <input type="hidden" name="SelectedCollegeId" value="@Model.SelectedCollegeId" />
        <input type="hidden" name="SelectedAcadYear" value="@Model.SelectedAcadYear" />

        <div class="col-md-4">
            <label class="form-label fw-semibold">Student Name</label>
            <input name="StudentName" type="text" class="form-control"
                   value="@Model.StudentName"
                   placeholder="LastName FirstName MiddleName"
                   id="studentNameInput"
                   autocomplete="off" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </form>

    @* {{!-- ── Student header ── --}} *@
    @if (!string.IsNullOrEmpty(Model.DisplayName))
    {
        <div class="card mb-3 border-primary">
            <div class="card-body py-2">
                <span class="fw-semibold me-3">Name: @Model.DisplayName</span>
                <span class="text-muted">Branch: @Model.DisplayBranch</span>
            </div>
        </div>
    }

    @* {{!-- ── Year-wise fee summary (Repeater equivalent) ── --}} *@
    @if (Model.FeesSummary.Any())
    {
        foreach (var yearSummary in Model.FeesSummary)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-header fw-semibold bg-light">
                    Academic Year: @yearSummary.AcadYear
                </div>
                <div class="card-body p-0">
                    @if (yearSummary.FeesMain.Any())
                    {
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-secondary">
                                <tr>
                                    <th>Receipt No</th>
                                    <th>Receipt Book</th>
                                    <th>Date</th>
                                    <th class="text-end">Amount (₹)</th>
                                    <th class="text-center">Details</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var fee in yearSummary.FeesMain)
                                {
                                    <tr>
                                        <td>@fee.FeesReceiptNo</td>
                                        <td>@fee.RptBookNo</td>
                                        <td>@fee.ReceiptDate</td>
                                        <td class="text-end">@fee.Amount.ToString("N2")</td>
                                        <td class="text-center">
                                            <button class="btn btn-xs btn-outline-info"
                                                    onclick="loadFeeDetails(
                                                @Model.SelectedCollegeId,
                                                '@ViewBag.StudId',
                                                '@ViewBag.ClassLevel',
                                                '@yearSummary.AcadYear',
                                                @fee.FeesReceiptNo,
                                                @fee.RptBookNo,
                                                this)">
                                                View
                                            </button>
                                        </td>
                                    </tr>
                                    @* { { !--Detail row(hidden until expanded)--} } *@
                                    <tr class="detail-row d-none" id="detail-@fee.FeesReceiptNo">
                                        <td colspan="5" class="p-0">
                                            <div class="detail-content p-2 bg-light"></div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted p-3 mb-0">No receipts found for this year.</p>
                    }
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        function loadFeeDetails(collegeId, studId, classLevel, acadYear, feeRecNo, rptBookNo, btn) {
            const detailRow = document.getElementById('detail-' + feeRecNo);
            const content   = detailRow.querySelector('.detail-content');

            // Toggle if already open
            if (!detailRow.classList.contains('d-none')) {
                detailRow.classList.add('d-none');
                return;
            }

            // Close all other open detail rows
            document.querySelectorAll('.detail-row').forEach(r => r.classList.add('d-none'));

            content.innerHTML = '<div class="text-center"><div class="spinner-border spinner-border-sm"></div></div>';
            detailRow.classList.remove('d-none');

            const url = `@Url.Action("GetFeeDetails", "StudFeesLedger", new { area = "Society" })`
                + `?collegeId=${collegeId}&studId=${studId}&classLevel=${classLevel}`
                + `&acadYear=${acadYear}&feeRecNo=${feeRecNo}&rptBookNo=${rptBookNo}`;

            fetch(url)
                .then(r => r.json())
                .then(data => {
                    if (!data.success || !data.data.length) {
                        content.innerHTML = '<p class="text-muted mb-0">No details available.</p>';
                        return;
                    }
                    let html = '<table class="table table-sm table-bordered mb-0">'
                        + '<thead><tr><th>Fee Description</th><th class="text-end">Amount (₹)</th>'
                        + '<th class="text-end">Balance (₹)</th></tr></thead><tbody>';
                    data.data.forEach(r => {
                        html += `<tr>
                            <td>${r.feeDescription}</td>
                            <td class="text-end">${r.amount}</td>
                            <td class="text-end ${r.balanceClass}">${r.balance}</td>
                        </tr>`;
                    });
                    html += '</tbody></table>';
                    content.innerHTML = html;
                })
                .catch(() => { content.innerHTML = '<p class="text-danger mb-0">Failed to load details.</p>'; });
        }
    </script>
}
